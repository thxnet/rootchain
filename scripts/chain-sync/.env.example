# PostgreSQL connection (required)
PG_URL=postgresql://user:password@host:5432/dbname

# Network selection (optional, default: mainnet)
# NETWORK=mainnet
# NETWORK=testnet

# Override RPC endpoint (optional, overrides NETWORK preset)
# RPC_ENDPOINT=wss://custom-node:9944/ws

# Override HTTP RPC endpoint for block fetching (optional, overrides NETWORK preset)
# HTTP_RPC_ENDPOINT=https://custom-node:9933/http-rpc
